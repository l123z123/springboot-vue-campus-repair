<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.repair.mapper.SysUserMapper">

    <select id="selectByUsername" resultType="com.campus.repair.entity.SysUser">
        SELECT * FROM sys_user WHERE username = #{username} AND is_deleted = 0 LIMIT 1
    </select>
</mapper>
